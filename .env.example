# 复制此文件为 .env 并填入真实值
# cp .env.example .env
#
# 房间号不写在此文件：网页开局后由后端写入 last_local_room.txt；命令行可设环境变量 ROOM_ID 或 --room-id。

# ── 游戏后端 ──────────────────────────────────────
BACKEND_URL=http://127.0.0.1:8000

# ── LLM 配置 ──────────────────────────────────────
# 硅基流动：https://cloud.siliconflow.cn/account/ak
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
LLM_BASE_URL=https://api.siliconflow.cn/v1
# 推荐模型：
#   Qwen/Qwen2.5-72B-Instruct        （性价比高）
#   deepseek-ai/DeepSeek-V3           （推理强）
#   Pro/deepseek-ai/DeepSeek-R1       （思维链最强，较慢）
LLM_MODEL=Qwen/Qwen2.5-72B-Instruct

# ── 轮询间隔（秒） ────────────────────────────────
POLL_INTERVAL=3

# ── AI 玩家（player_id:显示名称） ────────────────
AI_PLAYERS=p2:Bob,p3:Charlie,p4:Diana,p5:Eve,p6:Frank

# ── 真人玩家 ──────────────────────────────────────
HUMAN_PLAYER_ID=p1
HUMAN_PLAYER_NAME=你的名字

# ── 主持人（可选）──────────────────────────────────
# 设置后可用 GET /game/{room_id}/host_state + Header X-Host-Secret 查看全场身份
# HOST_SECRET=随便写一串长密码
